---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    description: string;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const dateStr = frontmatter.date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article>
    <header class="post-header">
      <a href="/" class="back-link">&larr; Back to Blog</a>
      <h1 class="gradient-text">{frontmatter.title}</h1>
      <div class="meta">
        <time datetime={frontmatter.date.toISOString().slice(0, 10)}>{dateStr}</time>
      </div>
      <div class="tags">
        {frontmatter.tags.map((tag: string) => (
          <a href={`/tags/${tag}/`} class="tag">#{tag}</a>
        ))}
      </div>
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
</BaseLayout>
