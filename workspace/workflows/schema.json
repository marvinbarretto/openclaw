{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jimbo Workflow Definition Schema",
  "type": "object",
  "required": ["id", "enabled", "description", "schedule", "intake", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Workflow identifier (kebab-case)"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether workflow is active"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "schedule": {
      "type": "string",
      "description": "Cron schedule (e.g., '0 9,15,18 * * *')"
    },
    "intake": {
      "type": "object",
      "required": ["source", "filter"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["vault-api", "email-api", "calendar-api"]
        },
        "filter": {
          "type": "string",
          "description": "Query filter (source-dependent syntax)"
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Step identifier (kebab-case)"
          },
          "type": {
            "type": "string",
            "enum": ["classify", "decision", "delegate", "review"]
          },
          "model": {
            "type": "string",
            "enum": ["haiku", "sonnet", "opus", "flash"]
          },
          "prompt_file": {
            "type": "string",
            "description": "Path to prompt file (relative to workspace/prompts/)"
          },
          "output_schema": {
            "type": "object",
            "description": "Expected output schema for classify step"
          },
          "rules": {
            "type": "array",
            "description": "Decision rules for decision step",
            "items": {
              "type": "object",
              "required": ["if", "action"],
              "properties": {
                "if": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                }
              }
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "default": 300
          },
          "fallback_model": {
            "type": "string"
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "human_feedback": {
      "type": "object",
      "properties": {
        "channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["telegram", "site-ui"]
          }
        },
        "notify_async": {
          "type": "boolean"
        },
        "decision_override": {
          "type": "boolean"
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "destination": {
          "type": "string",
          "enum": ["jimbo-api", "stdout"]
        },
        "track": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "config_hash": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
